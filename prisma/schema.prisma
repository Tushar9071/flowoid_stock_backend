generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  phone        String   @unique
  passwordHash String
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens AuthRefreshToken[]
  createdRoles  Role[]             @relation("CreatedRoles")
  tenantUsers   TenantUser[]
  rawMaterialPurchases RawMaterialPurchase[]
  rawMaterialIssuances RawMaterialIssuance[]
  @@map("users")

}

enum PartyType {
  DEALER
  SUPPLIER
}

enum PartyOpeningBalanceType {
  RECEIVABLE
  PAYABLE
}

enum PartyLedgerEntryType {
  OPENING_BALANCE
  SALE
  PURCHASE
  PAYMENT_RECEIVED
  PAYMENT_MADE
  CREDIT_NOTE
  DEBIT_NOTE
  ADJUSTMENT
  JOURNAL
}

enum RawMaterialUnit {
  KG
  GRAM
  PIECE
  METER
  DOZEN
}

enum RawMaterialPurchaseStatus {
  PENDING    // recorded but not yet received
  RECEIVED   // material received in stock
  CANCELLED  // purchase cancelled
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model Tenant {
  id                 String       @id @default(uuid())
  name               String
  slug               String       @unique
  email              String?
  phone              String?
  address            String?
  status             TenantStatus @default(TRIAL)
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  logoUrl            String?
  businessCategory   String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  users              TenantUser[]
  parties            Party[]
  partyLedgerEntries PartyLedgerEntry[]
  rawMaterialTypes     RawMaterialType[]
  rawMaterialPurchases RawMaterialPurchase[]
  rawMaterialIssuances RawMaterialIssuance[]

  @@map("tenants")
}

model Party {
  id                 String                  @id @default(uuid())
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId           String
  type               PartyType
  name               String
  code               String?
  contactPerson      String?
  phone              String?
  alternatePhone     String?  
  email              String?
  gstin              String?
  pan                String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  creditPeriodDays   Int?
  creditLimit        Decimal?                @db.Decimal(18, 2)
  openingBalance     Decimal                 @default(0) @db.Decimal(18, 2)
  openingBalanceType PartyOpeningBalanceType @default(RECEIVABLE)
  openingBalanceDate DateTime?
  notes              String?
  isActive           Boolean                 @default(true)
  deletedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  ledgerEntries      PartyLedgerEntry[]

  @@index([tenantId, type, isActive])
  @@index([tenantId, name])
  @@index([tenantId, phone])
  @@map("parties")
  rawMaterialPurchases RawMaterialPurchase[]
}

model RawMaterialType {
  id          String          @id @default(uuid())
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  name        String
  unit        RawMaterialUnit
  description String?
  isActive    Boolean         @default(true)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  purchases  RawMaterialPurchase[]
  issuances  RawMaterialIssuance[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("raw_material_types")
}

model RawMaterialPurchase {
  id             String                    @id @default(uuid())
  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  materialType   RawMaterialType           @relation(fields: [materialTypeId], references: [id])
  materialTypeId String
  supplier       Party                     @relation(fields: [supplierId], references: [id])
  supplierId     String
  quantity       Decimal                   @db.Decimal(18, 4)
  costPerUnit    Decimal                   @db.Decimal(18, 2)
  totalCost      Decimal                   @db.Decimal(18, 2)
  status         RawMaterialPurchaseStatus @default(RECEIVED)
  purchaseDate   DateTime
  invoiceNumber  String?
  notes          String?
  deletedAt      DateTime?
  createdBy      User                      @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([tenantId, materialTypeId])
  @@index([tenantId, supplierId])
  @@index([tenantId, purchaseDate])
  @@index([tenantId, status])
  @@map("raw_material_purchases")
}

model RawMaterialIssuance {
  id             String          @id @default(uuid())
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  materialType   RawMaterialType @relation(fields: [materialTypeId], references: [id])
  materialTypeId String
  quantity       Decimal         @db.Decimal(18, 4)
  issuedTo       String?         // free text or reference — worker name / assignment ref
  referenceId    String?         // will link to WorkerAssignment id in future
  referenceType  String?         // e.g. "WORKER_ASSIGNMENT" — for polymorphic future use
  issuedAt       DateTime        @default(now())
  notes          String?
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([tenantId, materialTypeId])
  @@index([tenantId, issuedAt])
  @@index([tenantId, referenceId])
  @@map("raw_material_issuances")
}

model PartyLedgerEntry {
  id             String               @id @default(uuid())
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  party          Party                @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId        String
  entryDate      DateTime
  entryType      PartyLedgerEntryType
  voucherType    String?
  voucherId      String?
  referenceNo    String?
  description    String?
  debitAmount    Decimal              @default(0) @db.Decimal(18, 2)
  creditAmount   Decimal              @default(0) @db.Decimal(18, 2)
  runningBalance Decimal?             @db.Decimal(18, 2)
  isOpeningEntry Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([tenantId, entryDate])
  @@index([partyId, entryDate])
  @@index([partyId, entryType])
  @@map("party_ledger_entries")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([roleId])
  @@map("tenant_users")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique // e.g. "orders.create"
  name        String // e.g. "Create Orders"
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id          String   @id @default(uuid())
  name        String // e.g. "SUPER_ADMIN", "TENANT_OWNER", "Cashier"
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]
  tenantUsers TenantUser[]
  createdBy   User?            @relation("CreatedRoles", fields: [createdById], references: [id])
  createdById String?

  @@map("roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  grantedAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AuthRefreshToken {
  id                String    @id
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  tokenHash         String    @unique
  sessionId         String
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  revokedAt         DateTime?
  revokedReason     String?
  replacedByTokenId String?

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("auth_refresh_tokens")
}
