# Environment Variables configuration
# Copy this file to .env and replace the values with your actual configuration

# Database
# Provide your PostgreSQL database connection string
DATABASE_URL="postgresql://user:password@host:port/database_name"

# Server Configuration
PORT="3000"

# Authentication (JWT)
# Generate secure random strings for your secrets (e.g., using `openssl rand -hex 32`)
JWT_SECRET="your_jwt_secret"
JWT_EXPIRES_IN="7d"

JWT_ACCESS_SECRET="your_jwt_access_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"

# Token expiration times
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cookie Configuration
AUTH_COOKIE_SAME_SITE="lax"
